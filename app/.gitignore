#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config (manual setup per dev — generated by `flutterfire configure`)
**/firebase_options.dart
**/google-services.json
**/GoogleService-Info.plist

# Gemma weights (too big for git, downloaded separately per MANUAL_SETUP.md)
**/*.task

# OSM bundled graph (generated by tools/extract_osm.py)
**/assets/road_graph.bin

# Env / secrets
.env
.env.local
